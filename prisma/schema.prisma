generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TemplateType {
  movie
  book
  music
  food
  place
  gift
  date
  people_notes
  custom
}

enum ViewMode {
  grid
  list
  cozy
}

enum PersonDetailSection {
  likes
  dislikes
  food
  movies
  books
  gifts
  date_ideas
  notes
}

model Profile {
  id                  String   @id @default(cuid())
  clerkUserId         String   @unique
  displayName         String
  themeColor          String?
  onboardingCompleted Boolean  @default(false)
  demoSeeded          Boolean  @default(false)
  checklistDismissed  Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  lists         List[]
  items         ListItem[]
  people        Person[]
  personDetails PersonDetail[]
  scraps        Scrap[]
  analyticsEvents AnalyticsEvent[]
}

model List {
  id              String       @id @default(cuid())
  userId          String
  title           String
  emoji           String
  templateType    TemplateType
  themeColor      String
  defaultViewMode ViewMode     @default(cozy)
  description     String?
  pinned          Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user  Profile    @relation(fields: [userId], references: [clerkUserId], onDelete: Cascade)
  items ListItem[]

  @@index([userId])
}

model ListItem {
  id        String   @id @default(cuid())
  listId    String
  userId    String
  title     String
  subtitle  String?
  note      String?
  status    String?
  emoji     String?
  imageUrl  String?
  tags      String[] @default([])
  metadata  Json     @default("{}")
  position  Int?
  pinned    Boolean  @default(false)
  personId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  list   List    @relation(fields: [listId], references: [id], onDelete: Cascade)
  user   Profile @relation(fields: [userId], references: [clerkUserId], onDelete: Cascade)
  person Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([listId])
  @@index([userId])
  @@index([personId])
}

/** First-party, privacy-conscious product events. Properties must never contain
 * free-form user content such as titles, notes, names, or search text. */
model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String
  name       String
  properties Json     @default("{}")
  sessionId  String?
  path       String?
  dedupeKey  String?  @unique
  createdAt  DateTime @default(now())

  user Profile @relation(fields: [userId], references: [clerkUserId], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([name, createdAt])
}

model Person {
  id         String   @id @default(cuid())
  userId     String
  name       String
  emoji      String
  shortNote  String?
  themeColor String?
  /** an optional day worth remembering, stored as "MM-DD" (no year, by design) */
  specialDay String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    Profile        @relation(fields: [userId], references: [clerkUserId], onDelete: Cascade)
  details PersonDetail[]
  items   ListItem[]

  @@index([userId])
}

model PersonDetail {
  id        String              @id @default(cuid())
  personId  String
  userId    String
  section   PersonDetailSection
  title     String
  note      String?
  tags      String[]            @default([])
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  person Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  user   Profile @relation(fields: [userId], references: [clerkUserId], onDelete: Cascade)

  @@index([personId])
  @@index([userId])
}

model Scrap {
  id     String @id @default(cuid())
  userId String
  text   String
  /** cached enrichment guess: {kind,title,subtitle,imageUrl?,sourceId,meta} or {none:true}; null = unchecked */
  detection Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user Profile @relation(fields: [userId], references: [clerkUserId], onDelete: Cascade)

  @@index([userId])
}
